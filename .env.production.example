# ========================================
# Production Environment Variables
# ========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with actual secrets.

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- NextAuth.js ---
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
# Set to your production URL (no trailing slash)
NEXTAUTH_URL=https://your-domain.com

# --- AI Provider API Keys ---
# At least one is required for the changelog feature.
# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Sentry Error Monitoring (Optional) ---
# Create project at: https://sentry.io/
# DSN is public and can be committed (it's just a destination URL)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# For source map uploads (keep these secret)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-name
SENTRY_AUTH_TOKEN=your_auth_token

# --- Base Path (Optional) ---
# Deploy to a subdirectory: /dashboard
# Leave unset or empty for root deployment
# NEXT_PUBLIC_BASE_PATH=/dashboard
